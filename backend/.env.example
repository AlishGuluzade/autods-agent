# Copy this file to .env and fill in your key to enable real LLM planning/explanations.
# Without it, the agent falls back to heuristic (rule-based) planning and explanations --
# the whole pipeline still runs end-to-end, just without LLM reasoning.

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# Where uploaded datasets and run artifacts (models, charts, reports) are stored.
UPLOAD_DIR=/tmp/autods_uploads
ARTIFACTS_DIR=/tmp/autods_artifacts
